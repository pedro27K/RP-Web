# ============================================================
#  RP TRAVELS — PLANTILLA DE VARIABLES DE ENTORNO
# ------------------------------------------------------------
#  1) Copia este archivo a ".env": 
#  2) Rellena los valores reales.
# ============================================================

# --- Base de datos ---
# Usa el usuario de aplicación 'rp_app' (ver sql/rp.sql),
# no el usuario root ni uno con todos los privilegios.
DB_HOST=db
DB_USER=rp_app
DB_PASS=cambia_esta_clave
DB_NAME=rp_travels

# --- Correo saliente (Gmail con contraseña de aplicación) ---
# Genera una "contraseña de aplicación" desde la cuenta de Google:
#   Cuenta de Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
MAIL_USER=tu_correo@gmail.com
MAIL_PASS=xxxx xxxx xxxx xxxx
